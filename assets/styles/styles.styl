body
  background-color: #F3F3F3
  body_font()
  font-size: 18px
  margin-top: 2rem;

h1, h2, h3, h4, h5, h6
  headline_font()

h1
  color: #333
  font-size: 2rem
  font-style: normal
  margin-bottom: 0.75rem

p
  color: #666
  font-size: 0.9rem
  line-height: 1.1rem
  margin: 0

ul
  margin: .5rem 0 0 0
  padding: 0
  text-align: center

li
  color: #999
  display: inline-block
  font-size: 0.8rem
  text-transform: lowercase


  &::after
    content: "•"

  &:last-child::after
    content: none

a
  color: #244279
  transition color transition_duration ease

  &:hover, &:active
    color: #9B114D

#container
  margin: 0 auto
  width: 350px
