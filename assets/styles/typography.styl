@import 'variables'

body
  font-family: "Ideal Sans SSm A", "Ideal Sans SSm B"
  font-weight: 400

strong, h1, h2, h3, h4, h5, h6
  font-weight: 600

h1
  font-size: 5em
  margin: 0

h2
  font-size: 1.5em

p
  font-size: 1.2em
  line-height: 1.6em
  margin: 1.5em 0

q
  font-style: italic

// two-column viewport
@media $two-column-media-query
  h1
    font-size: 4em

  h2
    font-size: 1.5em

  p
    font-size: 1.1em
